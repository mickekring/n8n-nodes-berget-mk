{
  "name": "n8n-nodes-berget-mk",
  "version": "0.3.0",
  "description": "n8n community node for Berget AI. One multi-resource action node (chat, embeddings, OCR, speech-to-text, rerank) plus a Chat Model sub-node that plugs into n8n's built-in AI Agent.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "berget-ai",
    "berget",
    "ai",
    "llm",
    "chat",
    "embeddings",
    "ocr",
    "speech",
    "rerank",
    "langchain",
    "ai-agent"
  ],
  "license": "MIT",
  "homepage": "https://github.com/mickekring/n8n-nodes-berget-mk",
  "author": "Micke Kring",
  "repository": {
    "type": "git",
    "url": "https://github.com/mickekring/n8n-nodes-berget-mk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "index.js",
  "scripts": {
    "build": "rm -rf dist && tsc && node scripts/copy-assets.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist node_modules"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "axios": "^1.12.2",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.3",
    "@types/node": "^20.11.0",
    "n8n-workflow": "^2.16.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@langchain/core": "*",
    "@langchain/openai": "*",
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/BergetAiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/BergetAi/BergetAi.node.js",
      "dist/nodes/BergetAiChatModel/BergetAiChatModel.node.js"
    ]
  }
}
