{
  "name": "n8n-nodes-berget-mk",
  "version": "0.1.1",
  "description": "n8n community nodes for Berget AI — chat, agent, embeddings, OCR, speech, and rerank.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "berget-ai",
    "berget",
    "ai",
    "llm",
    "agent",
    "chat",
    "embeddings",
    "ocr",
    "speech",
    "rerank",
    "tools"
  ],
  "license": "MIT",
  "homepage": "https://github.com/mickekring/n8n-nodes-berget-mk",
  "author": "Micke Kring",
  "repository": {
    "type": "git",
    "url": "https://github.com/mickekring/n8n-nodes-berget-mk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "index.js",
  "scripts": {
    "build": "rm -rf dist && tsc && node scripts/copy-assets.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist node_modules"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "axios": "^1.12.2",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "n8n-workflow": "^1.17.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/BergetAiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/BergetAiAgent/BergetAiAgent.node.js",
      "dist/nodes/BergetAiChat/BergetAiChat.node.js",
      "dist/nodes/BergetAiEmbeddings/BergetAiEmbeddings.node.js",
      "dist/nodes/BergetAiOcr/BergetAiOcr.node.js",
      "dist/nodes/BergetAiRerank/BergetAiRerank.node.js",
      "dist/nodes/BergetAiSpeech/BergetAiSpeech.node.js"
    ]
  }
}
